#!/usr/bin/env bash

set -euo pipefail

repo_root=$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)
test_root=$(mktemp -d "${TMPDIR:-/tmp}/tts29-setup-test.XXXXXX")
trap 'rm -rf "$test_root"' EXIT

config="$test_root/config/daemon.json"
env_file="$test_root/config/env"
output="$test_root/output"
secret_marker='nsec1must-not-appear-in-output'

run_setup() {
  TTS29_CONFIG="$config" TTS29_ENV_FILE="$env_file" \
    "$repo_root/scripts/setup" "$@" >"$output" 2>&1
}

if run_setup --check; then
  echo "empty setup unexpectedly passed" >&2
  exit 1
fi
grep -Fq "daemon config is missing" "$output"

if run_setup --init; then
  echo "placeholder setup unexpectedly passed" >&2
  exit 1
fi
[[ -f $config && -f $env_file ]]
[[ $(stat -f '%Lp' "$(dirname "$config")") == 700 ]]
[[ $(stat -f '%Lp' "$config") == 600 ]]
[[ $(stat -f '%Lp' "$env_file") == 600 ]]
grep -Fq "Kokoro endpoint must be a non-placeholder" "$output"

jq '.kokoro.endpoint = "https://speech.example.net/v1/audio/speech"
  | .blossom.server = "https://blossom.example.net"
  | .owner_pubkey = ("a" * 64)' "$config" >"$config.next"
mv "$config.next" "$config"
chmod 600 "$config"
printf "TTS29_DAEMON_NSEC='%s'\n" "$secret_marker" >"$env_file"
chmod 600 "$env_file"

run_setup --check
grep -Fq "TTS29 local setup checks passed" "$output"
grep -Fq "daemon identity will be generated privately on first start" "$output"
if grep -Fq "$secret_marker" "$output"; then
  echo "setup check exposed a secret value" >&2
  exit 1
fi

printf '%s\n' "setup helper checks passed"
