// Shared.xcconfig
// Minimal shared configuration for scaffold tool customization
// All other settings use Xcode project defaults
// Generated by XcodeBuildMCP

// ==========================================
// Project Identity
// ==========================================
PRODUCT_NAME = TTS29Mac
PRODUCT_DISPLAY_NAME = TTS29
PRODUCT_BUNDLE_IDENTIFIER = com.pablof7z.tts29.macos
MARKETING_VERSION = 0.1.0
CURRENT_PROJECT_VERSION = 1

// ==========================================
// Platform Configuration
// ==========================================
MACOSX_DEPLOYMENT_TARGET = 14.0
ALWAYS_SEARCH_USER_PATHS = NO

// The shared app kernel is built by scripts/build-rust-macos.sh. Swift owns
// rendering and native media execution; NMP remains the only Nostr boundary.
LIBRARY_SEARCH_PATHS = $(inherited) $(SRCROOT)/../../core/target/release
OTHER_LDFLAGS = $(inherited) -ltts29_core

// ==========================================
// Info PLIST
// ==========================================
GENERATE_INFOPLIST_FILE = YES

// ==========================================
// Entitlements
// ==========================================
CODE_SIGN_ENTITLEMENTS = Config/TTS29Mac.entitlements
