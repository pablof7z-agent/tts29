// Shared.xcconfig
// Minimal shared configuration for scaffold tool customization
// All other settings use Xcode project defaults
// Generated by XcodeBuildMCP

// ==========================================
// Project Identity
// ==========================================
PRODUCT_NAME = TTS29
PRODUCT_DISPLAY_NAME = TTS29
PRODUCT_BUNDLE_IDENTIFIER = com.pablof7z.tts29
MARKETING_VERSION = 0.1.0
CURRENT_PROJECT_VERSION = 1
DEVELOPMENT_TEAM = 456SHKPP26

// ==========================================
// Platform Configuration
// ==========================================
IPHONEOS_DEPLOYMENT_TARGET = 17.0

// The app-specific Rust kernel is built by scripts/build-rust-ios.sh. Swift
// sees only its small event-driven C boundary; all Nostr behavior stays in
// the Rust kernel through NMP.
LIBRARY_SEARCH_PATHS = $(inherited)
LIBRARY_SEARCH_PATHS[sdk=iphonesimulator*] = $(inherited) $(SRCROOT)/../core/target/aarch64-apple-ios-sim/release
LIBRARY_SEARCH_PATHS[sdk=iphoneos*] = $(inherited) $(SRCROOT)/../core/target/aarch64-apple-ios/release
OTHER_LDFLAGS = $(inherited) -ltts29_core

// (1 == iPhone, 2 == iPad)
TARGETED_DEVICE_FAMILY = 1,2

// ==========================================
// Info PLIST
// ==========================================
GENERATE_INFOPLIST_FILE = YES
INFOPLIST_KEY_ITSAppUsesNonExemptEncryption = NO
INFOPLIST_KEY_UISupportedInterfaceOrientations = UIInterfaceOrientationLandscapeRight UIInterfaceOrientationLandscapeLeft UIInterfaceOrientationPortrait
INFOPLIST_KEY_UISupportedInterfaceOrientations_iPad = UIInterfaceOrientationLandscapeRight UIInterfaceOrientationLandscapeLeft UIInterfaceOrientationPortrait UIInterfaceOrientationPortraitUpsideDown

// ==========================================
// Entitlements
// ==========================================
// AI agents can modify Config/TTS29.entitlements to add capabilities
CODE_SIGN_ENTITLEMENTS = Config/TTS29.entitlements
